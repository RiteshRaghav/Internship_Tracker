# Backend environment variables (for export in your shell or IDE run config)
# Note: Spring Boot does not automatically read .env files. Use `export VAR=value`, your IDE, or tools like direnv.

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/internship_tracker
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=7903664492

# JWT
JWT_SECRET=
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080

# File uploads
FILE_UPLOAD_DIR=uploads
MAX_FILE_SIZE=15MB
MAX_REQUEST_SIZE=20MB

# Frontend base URL (used in password reset links)
FRONTEND_BASE_URL=http://localhost:3000

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=no-reply@internship-tracker.local
